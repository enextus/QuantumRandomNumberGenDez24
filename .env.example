# ================================
# Quantum Random Number Generator — Environment Configuration
# ================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is git-ignored and will NOT be committed.
# Variable names follow the convention: QRNG_ + UPPER_SNAKE_CASE
# For example, config key "api.key" → QRNG_API_KEY
#
# Priority order (highest to lowest):
#   1. System environment variables
#   2. .env file (this file, after copying)
#   3. config.properties (fallback defaults)
# ================================

# Your ANU Quantum Random Numbers API key
# Get one at: https://quantumnumbers.anu.edu.au
QRNG_API_KEY=

# Optional overrides (uncomment to use):
# QRNG_API_URL=https://api.quantumnumbers.anu.edu.au
# QRNG_API_DATA_TYPE=uint16
# QRNG_API_ARRAY_LENGTH=1024
# QRNG_LOG_LEVEL=INFO
